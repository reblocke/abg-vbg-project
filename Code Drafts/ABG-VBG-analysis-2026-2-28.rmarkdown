  list(pred_imv, pred_niv, pred_death, pred_hcrf,
       pred_imv_vbg, pred_niv_vbg, pred_death_vbg, pred_hcrf_vbg),
  lo_col = "p_LCL", hi_col = "p_UCL"
)

# helper: plot one unweighted ABG predicted-probability spline panel using the
# shared probability axis computed across outcomes.
plot_prob_abg <- function(dat, title_txt) {
  ggplot(dat, aes(x = paco2, y = p)) +
    geom_line(color = "#1f77b4", linewidth = 1.0) +
    geom_ribbon(aes(ymin = p_LCL, ymax = p_UCL), fill = "#1f77b4", alpha = 0.2) +
    prob_axis_scale(axis_unw_prob) +
    labs(
      title = title_txt,
      x = "PaCO2 (mmHg)",
      y = "Predicted probability",
      caption = paste0("Conditional on reference covariate profile X_ref; ref PaCO2 = ", co2_ref_abg_unw, " mmHg")
    ) +
    theme_pub()
}

# helper: plot one unweighted VBG predicted-probability spline panel using the
# shared probability axis computed across outcomes.
plot_prob_vbg <- function(dat, title_txt) {
  ggplot(dat, aes(x = vbg_co2, y = p)) +
    geom_line(color = "#d95f02", linewidth = 1.0) +
    geom_ribbon(aes(ymin = p_LCL, ymax = p_UCL), fill = "#d95f02", alpha = 0.2) +
    prob_axis_scale(axis_unw_prob) +
    labs(
      title = title_txt,
      x = "VBG CO2 (mmHg)",
      y = "Predicted probability",
      caption = paste0("Conditional on reference covariate profile X_ref; ref VBG CO2 = ", co2_ref_vbg_unw, " mmHg")
    ) +
    theme_pub()
}

unw_abg_prob_panel <- (plot_prob_abg(pred_imv, "IMV (adjusted)") |
  plot_prob_abg(pred_niv, "NIV (adjusted)")) /
  (plot_prob_abg(pred_death, "Death (60d, adjusted)") |
     plot_prob_abg(pred_hcrf, "Hypercapnic RF (adjusted)")) +
  plot_annotation(
    title = paste0("Adjusted predicted probabilities by ABG CO2 (ref = ", co2_ref_abg_unw, ")"),
    caption = paste0("Probabilities are conditional on X_ref; reference PaCO2 = ", co2_ref_abg_unw, " mmHg")
  )

unw_vbg_prob_panel <- (plot_prob_vbg(pred_imv_vbg, "IMV (adjusted)") |
  plot_prob_vbg(pred_niv_vbg, "NIV (adjusted)")) /
  (plot_prob_vbg(pred_death_vbg, "Death (60d, adjusted)") |
     plot_prob_vbg(pred_hcrf_vbg, "Hypercapnic RF (adjusted)")) +
  plot_annotation(
    title = paste0("Adjusted predicted probabilities by VBG CO2 (ref = ", co2_ref_vbg_unw, ")"),
    caption = paste0("Probabilities are conditional on X_ref; reference VBG CO2 = ", co2_ref_vbg_unw, " mmHg")
  )

print_plot_once(unw_abg_prob_panel, "spline-unweighted-abg-prob", width = 8.5, height = 6)
print_plot_once(unw_vbg_prob_panel, "spline-unweighted-vbg-prob", width = 8.5, height = 6)

```

