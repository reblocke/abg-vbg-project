    theme_pub()

ipw_vbg_panel <- (patchwork::wrap_plots(
  plt(pred_imv_vbg,   "IMV"),
  plt(pred_niv_vbg,   "NIV"),
  plt(pred_death_vbg, "Death"),
  plt(pred_hcrf_vbg,  "Hypercapnic RF"),
  ncol = 2
)) +
  plot_annotation(
    title = paste0("GBM-IPSW-adjusted odds ratios by VBG CO2 (ref = ",
                   VBG_CO2_REF, "; conditional on X)"),
    caption = paste0("Reference VBG CO2 = ", VBG_CO2_REF, " mmHg")
  )

print_plot_once(ipw_vbg_panel, "spline-ipw-vbg", width = 8.5, height = 6)

# helper: draw one VBG IPW predicted-probability panel using the ABG/VBG-shared
# probability axis.
plt_prob_vbg <- function(dat, title)
  ggplot(dat, aes(vbg_co2, p)) +
    geom_line(color = "#d95f02") +
    geom_ribbon(aes(ymin = p_LCL, ymax = p_UCL), alpha = 0.2, fill = "#d95f02") +
    prob_axis_scale(axis_ipw_common_prob) +
    labs(title = title, x = xlab, y = "Predicted probability") +
    theme_pub()

ipw_vbg_prob_panel <- (patchwork::wrap_plots(
  plt_prob_vbg(pred_imv_vbg,   "IMV"),
  plt_prob_vbg(pred_niv_vbg,   "NIV"),
  plt_prob_vbg(pred_death_vbg, "Death"),
  plt_prob_vbg(pred_hcrf_vbg,  "Hypercapnic RF"),
  ncol = 2
)) +
  plot_annotation(
    title = paste0("GBM-IPSW-adjusted predicted probabilities by VBG CO2 (ref = ",
                   VBG_CO2_REF, "; conditional on X)"),
    caption = paste0("Probabilities are conditional on X_ref; reference VBG CO2 = ", VBG_CO2_REF, " mmHg")
  )

print_plot_once(ipw_vbg_prob_panel, "spline-ipw-vbg-prob", width = 8.5, height = 6)

# ABG plots with the same axis (shared with VBG)
xlab_abg <- expression(paste("ABG CO"[2], " (mmHg)"))

# helper: redraw the ABG IPW odds-ratio panels on the same axis used for VBG so
# the overlaid comparison figures remain visually comparable.
plt_abg <- function(dat, title)
  ggplot(dat, aes(paco2, OR)) +
    geom_line() +
    geom_ribbon(aes(ymin = LCL, ymax = UCL), alpha = 0.2) +
    geom_hline(yintercept = 1, linetype = "dashed", color = "grey40") +
    or_axis_scale(axis_ipw_common) +
    labs(title = title, x = xlab_abg,
         y = paste0("Odds ratio (ref = ", ABG_CO2_REF, "; log scale)")) +
    theme_pub()

ipw_abg_shared_panel <- (patchwork::wrap_plots(
  plt_abg(pred_imv_abg,   "IMV"),
  plt_abg(pred_niv_abg,   "NIV"),
  plt_abg(pred_death_abg, "Death"),
  plt_abg(pred_hcrf_abg,  "Hypercapnic RF"),
  ncol = 2
)) +
  plot_annotation(
    title = paste0("GBM-IPSW-adjusted odds ratios by ABG CO2 (ref = ",
                   ABG_CO2_REF, "; conditional on X)"),
    caption = paste0("Reference PaCO2 = ", ABG_CO2_REF, " mmHg")
  )

print_plot_once(ipw_abg_shared_panel, "spline-ipw-abg-shared", width = 8.5, height = 6)

