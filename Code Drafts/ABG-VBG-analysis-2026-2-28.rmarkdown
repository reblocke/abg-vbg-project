```{r supplement-artifact-manifest}
#| code-block-title: "Manuscript asset manifests"
#| include: true
#| echo: true
#| message: false
# Purpose: freeze manuscript-facing numbering, paths, aliases, and targeted duplicate cleanup.
# helper: delete only the known duplicate spill files for mapped supplement
# artifacts, leaving unrelated historical files untouched.
cleanup_targeted_supplement_duplicates <- function() {
  duplicate_map <- tibble::tribble(
    ~canonical_file, ~duplicate_file,
    results_path("figs", "propensity-histograms-conditional.png"), results_path("figs", "propensity-histograms-conditional-1.png"),
    results_path("figs", "shap-top10-ipw-gbm-abg-vbg.png"), results_path("figs", "shap-top10-ipw-gbm-display-1.png")
  )

  duplicate_map |>
    dplyr::rowwise() |>
    dplyr::mutate(
      remove_ok = file.exists(canonical_file) && file.exists(duplicate_file)
    ) |>
    dplyr::ungroup() |>
    dplyr::filter(remove_ok) |>
    dplyr::pull(duplicate_file) |>
    unique() |>
    (\(paths) {
      if (length(paths)) fs::file_delete(paths)
      invisible(paths)
    })()
}

cleanup_targeted_supplement_duplicates()

# helper: convert an internal absolute artifact path into the shorter manifest
# path used in CSV audits and drafting.
format_manifest_path <- function(path) {
  if (is.null(path) || is.na(path) || !nzchar(path)) return("")
  pretty_path(path)
}

# Canonical artifact names stay analysis-oriented for code stability, while
# alias artifact names are manuscript-facing and numbered/titled for drafting.
# The supplement manifest is derived from this unified registry so numbering and
# file paths cannot silently drift away from the notebook outputs.
manuscript_asset_manifest_internal <- tibble::tribble(
  ~manuscript_label, ~title, ~kind, ~section, ~chunk_label, ~status, ~notes, ~analysis_family, ~canonical_subdir, ~canonical_stub, ~alias_subdir, ~alias_stub, ~primary_ext,
  "Figure 1", "Cohort assembly and target population for inverse probability-of-sampling weighting", "figure", "main", "cohort-flow-figure", "generated", "Primary cohort-flow display; .pdf sidecar also generated.", "main", "", "cohort_flow", "figs", "figure_1_cohort_assembly_target_population_ipsw", "png",
  "Figure 2", "Primary MI-logistic IPSW-weighted spline associations of pCO2 with clinical outcomes by ABG and VBG", "figure", "main", "key-results-spline-main-mi-ipw-abg-vbg", "generated", "Combined manuscript-facing weighted spline figure from the primary MI-logistic IPSW analysis; .pdf sidecar also generated.", "main_mi_ipw_spline", "figs", "key-results-spline-main-mi-ipw-abg-vbg", "figs", "figure_2_primary_weighted_spline_associations_abg_vbg", "png",
  "Table 1", "Baseline characteristics of the analytic cohort overall and by receipt of arterial and venous blood gas testing", "table", "main", "table1-everyone-abg-vbg", "generated", "Rendered from the canonical tbl1/tbl1_combined_csv objects; paired CSV also generated.", "baseline", "", "table1_combined", "", "table_1_baseline_characteristics_analytic_cohort", "pdf",
  "Table 2", "MI-pooled, MI-logistic IPSW-weighted 3-level categorical results for ABG and VBG", "table", "main", "table2-weighted-categorical-outcomes", "generated", "Main manuscript table for weighted categorical ORs and predicted probabilities across ABG and VBG.", "main_mi_weighted_categorical", "", "table_2_weighted_categorical_outcomes", "", "table_2_weighted_categorical_outcomes", "pdf",
  "Figure S1", "Covariate balance after MI logistic inverse-probability weighting for ABG and VBG test-ordering models", "figure", "supplement", "loveplot-mi-logistic", "generated", "Primary balance diagnostic for the MI logistic IPSW analysis.", "mi_logistic_primary", "figs", "loveplot-mi-logistic-abg-vbg", "figs", "figure_s1_covariate_balance_mi_logistic_ipsw", "png",
  "Figure S2", "Propensity-score overlap for MI logistic ABG and VBG test-ordering models", "figure", "supplement", "mi-propensity-histograms-logistic", "generated", "Imputation-averaged tested-versus-untested propensity-score distributions under the MI logistic IPSW models.", "mi_logistic_primary", "figs", "propensity-histograms-mi-logistic", "figs", "figure_s2_propensity_score_overlap_mi_logistic", "png",
  "Figure S3", "SHAP-style contribution summaries for MI logistic ABG and VBG test-ordering models", "figure", "supplement", "shap-top10-mi-logistic-display", "generated", "Mean absolute contribution summaries from the MI logistic IPSW test-ordering models.", "mi_logistic_primary", "figs", "shap-top10-mi-logistic-abg-vbg", "figs", "figure_s3_shap_style_contributions_mi_logistic", "png",
  "Figure S4", "MI-logistic IPSW-weighted categorical associations of pCO2 category with clinical outcomes by ABG and VBG", "figure", "supplement", "key-results-cat3-main-mi-ipw-abg-vbg", "generated", "Weighted categorical display from the primary MI-logistic IPSW analysis, intentionally harmonized as Figure S4 rather than a main-text Figure 3.", "mi_weighted_categorical", "figs", "key-results-cat3-main-mi-ipw-abg-vbg", "figs", "figure_s4_weighted_categorical_associations_abg_vbg", "png",
  "Figure S5", "Unweighted covariate-adjusted spline associations of pCO2 with clinical outcomes by ABG and VBG", "figure", "supplement", "key-results-spline-adjusted-abg-vbg", "generated", "Combined adjusted complete-case spline figure; .pdf sidecar also generated.", "unweighted_adjusted", "figs", "key-results-spline-adjusted-abg-vbg", "figs", "figure_s5_unweighted_adjusted_spline_abg_vbg", "png",
  "Table S2", "Crude associations of pCO2 category with clinical outcomes by ABG and VBG", "table", "supplement", "supplement-table-s2-crude", "generated", "Standalone crude categorical odds-ratio table; paired CSV also generated.", "crude", "", "table_s2_crude_threelevel", "", "table_s2_crude_threelevel", "pdf",
  "Table S3", "GBM IPSW-weighted associations of pCO2 category with clinical outcomes by ABG and VBG", "table", "supplement", "supplement-table-s3-gbm", "generated", "Standalone GBM IPSW-weighted categorical odds-ratio table; paired CSV also generated.", "gbm_sensitivity", "", "table_s3_gbm_threelevel", "", "table_s3_gbm_threelevel", "pdf",
  "Figure S6", "Covariate balance after gradient-boosted propensity weighting for ABG and VBG test-ordering models", "figure", "supplement", "loveplot-ipw-gbm", "generated", "Raw-versus-weighted absolute standardized mean differences; dashed line marks |SMD| = 0.1.", "gbm_sensitivity", "figs", "loveplot-ipw-gbm-abg-vbg", "figs", "figure_s6_covariate_balance_gbm_weighting", "png",
  "Figure S7", "Propensity-score overlap for gradient-boosted ABG and VBG test-ordering models", "figure", "supplement", "propensity-histograms-conditional", "generated", "Tested-versus-untested propensity-score distributions under the GBM sensitivity models.", "gbm_sensitivity", "figs", "propensity-histograms-conditional", "figs", "figure_s7_propensity_score_overlap_gbm", "png",
  "Figure S8", "SHAP-style contribution summaries for gradient-boosted ABG and VBG test-ordering models", "figure", "supplement", "shap-top10-ipw-gbm-display", "generated", "Mean absolute SHAP value summaries; not interpreted as independent predictors.", "gbm_sensitivity", "figs", "shap-top10-ipw-gbm-abg-vbg", "figs", "figure_s8_shap_style_contributions_gbm", "png",
  "Supplementary Table 1", "Inclusion criteria into the enriched sample", "table", "supplement", "", "external/manual", "Defined outside the notebook; intentionally not generated here.", "external", "", "", "", "", "",
  "Figure 3", "Deprecated draft-only reference for weighted categorical results", "figure", "draft_only", "", "draft_only", "Weighted categorical display is intentionally harmonized as Figure S4; no Figure 3 alias is generated.", "deprecated", "", "", "", "", ""
) |>
  dplyr::mutate(
    canonical_artifact_file = mapply(
      artifact_file_path,
      stub = canonical_stub,
      ext = primary_ext,
      subdir = canonical_subdir,
      USE.NAMES = FALSE
    ),
    alias_artifact_file = mapply(
      artifact_file_path,
      stub = alias_stub,
      ext = primary_ext,
      subdir = alias_subdir,
      USE.NAMES = FALSE
    )
  )

# helper: write the manuscript-facing alias file(s) for one registered asset.
materialize_manuscript_alias <- function(kind, canonical_stub, alias_stub,
                                         canonical_subdir, alias_subdir) {
  if (kind == "figure") {
    return(write_plot_alias(canonical_stub, alias_stub, canonical_subdir, alias_subdir))
  }
  if (kind == "table") {
    return(write_table_alias(canonical_stub, alias_stub, canonical_subdir, alias_subdir))
  }
  stop("Unsupported artifact kind for manuscript alias: ", kind)
}

manuscript_asset_manifest_internal <- manuscript_asset_manifest_internal |>
  dplyr::rowwise() |>
  dplyr::mutate(
    alias_written = list(
      if (
        identical(status, "generated") &&
        !is.na(alias_stub) && nzchar(alias_stub) &&
        !is.na(canonical_stub) && nzchar(canonical_stub)
      ) {
        materialize_manuscript_alias(kind, canonical_stub, alias_stub, canonical_subdir, alias_subdir)
      } else {
        character(0)
      }
    )
  ) |>
  dplyr::ungroup() |>
  dplyr::mutate(
    canonical_artifact_path = vapply(canonical_artifact_file, format_manifest_path, character(1L)),
    alias_artifact_path = vapply(alias_artifact_file, format_manifest_path, character(1L))
  )

write_csv_safely(
  manuscript_asset_manifest_internal |>
    dplyr::select(
      manuscript_label, title, kind, section, chunk_label,
      canonical_artifact_path, alias_artifact_path, status, notes
    ),
  results_path("manuscript_asset_manifest.csv"),
  row_names = FALSE
)

supplement_manifest_internal <- manuscript_asset_manifest_internal |>
  dplyr::filter(section == "supplement") |>
  dplyr::transmute(
    supp_label = manuscript_label,
    title = title,
    analysis_family = analysis_family,
    artifact_path = alias_artifact_path,
    chunk_name = chunk_label,
    notes = notes,
    artifact_file = alias_artifact_file
  )

write_csv_safely(
  supplement_manifest_internal |>
    dplyr::select(-artifact_file),
  results_path("supplement_manifest.csv"),
  row_names = FALSE
)
```

```{r manuscript-facing-display}
#| code-block-title: "Manuscript-facing figure and table display"
#| include: true
#| echo: false
#| results: "asis"
#| message: false
# Purpose: display manuscript-facing assets in explicit manuscript order, independent of generation-chunk order.
manifest_row <- function(label) {
  row <- manuscript_asset_manifest_internal |>
    dplyr::filter(manuscript_label == label)
  if (nrow(row) != 1L) stop("Expected exactly one manifest row for ", label)
  row
}

# helper: resolve the display-ready figure path for one manifest label,
# preferring PDF for LaTeX output and falling back to PNG if needed.
manifest_figure_path <- function(label) {
  row <- manifest_row(label)
  ext <- if (knitr::is_latex_output()) "pdf" else "png"
  stub <- if (!is.na(row$alias_stub) && nzchar(row$alias_stub)) row$alias_stub else row$canonical_stub
  subdir <- if (!is.na(row$alias_subdir) && nzchar(row$alias_subdir)) row$alias_subdir else row$canonical_subdir
  path <- artifact_file_path(stub, ext, subdir)
  if (!file.exists(path)) {
    fallback_ext <- if (identical(ext, "pdf")) "png" else ext
    path <- artifact_file_path(stub, fallback_ext, subdir)
  }
  if (!file.exists(path)) stop("Missing display artifact for ", label, ": ", path)
  path
}

# helper: insert one manifest-registered figure into the rendered notebook in
# official manuscript order, independent of generation chunk order.
render_manuscript_figure <- function(label, width = "0.88\\linewidth") {
  row <- manifest_row(label)
  fig_path <- manifest_figure_path(label)
  caption_text <- paste0(label, ". ", row$title)
  if (knitr::is_latex_output()) {
    latex_caption <- escape_latex_text(caption_text)
    latex_path <- fs::path_rel(fig_path, start = qmd_dir)
    out <- c(
      "\\clearpage",
      "\\begin{center}",
      "\\begin{minipage}{\\linewidth}",
      "\\centering",
      sprintf("\\small %s\\par", latex_caption),
      "\\vspace{0.5em}",
      sprintf("\\includegraphics[width=%s,height=0.82\\textheight,keepaspectratio]{%s}", width, latex_path),
      "\\end{minipage}",
      "\\end{center}"
    )
    knitr::asis_output(paste(out, collapse = "\n"))
  } else {
    knitr::asis_output(
      paste0("![](", pretty_path(fig_path), ")\n\n*", caption_text, "*\n")
    )
  }
}

# helper: render one manifest-registered table with its manuscript label and
# title while reusing the standard standalone-table path.
render_manifest_table <- function(label, df, file_stub, wide = FALSE, digits = 2,
                                  max_cols = 6, landscape = NULL) {
  row <- manifest_row(label)
  render_table_pdf(
    df,
    caption = row$title,
    file_stub = file_stub,
    wide = wide,
    digits = digits,
    max_cols = max_cols,
    landscape = landscape,
    display_label = label,
    caption_mode = "plain",
    page_break_before = TRUE
  )
}

render_manuscript_figure("Figure 1")
render_manuscript_figure("Figure 2")
render_manifest_table(
  "Table 1",
  tbl1_combined_csv,
  file_stub = "table1_combined",
  wide = TRUE,
  digits = 2,
  max_cols = 8,
  landscape = TRUE
)
render_manifest_table(
  "Table 2",
  table_2_weighted_categorical_outcomes,
  file_stub = "table_2_weighted_categorical_outcomes",
  wide = TRUE,
  digits = 2,
  max_cols = 8,
  landscape = TRUE
)
render_manuscript_figure("Figure S1")
render_manuscript_figure("Figure S2")
render_manuscript_figure("Figure S3")
render_manuscript_figure("Figure S4")
render_manuscript_figure("Figure S5")
render_manifest_table(
  "Table S2",
  table_s2_crude_threelevel,
  file_stub = "table_s2_crude_threelevel",
  wide = TRUE,
  digits = 2
)
render_manifest_table(
  "Table S3",
  table_s3_gbm_threelevel,
  file_stub = "table_s3_gbm_threelevel",
  wide = TRUE,
  digits = 2
)
render_manuscript_figure("Figure S6")
render_manuscript_figure("Figure S7")
render_manuscript_figure("Figure S8")
