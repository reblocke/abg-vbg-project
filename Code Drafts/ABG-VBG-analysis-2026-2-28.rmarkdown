```{r manuscript-asset-audit}
#| code-block-title: "Manuscript-facing asset audit"
#| include: true
#| echo: true
#| results: "asis"
# Purpose: compact manuscript-facing asset audit table.
manuscript_asset_audit <- manuscript_asset_manifest_internal |>
  dplyr::mutate(
    existence_status = dplyr::case_when(
      status == "generated" &
        file.exists(canonical_artifact_file) &
        file.exists(alias_artifact_file) ~ "generated",
      status == "external/manual" ~ "external/manual",
      status == "draft_only" ~ "draft_only",
      status == "generated" ~ "missing",
      TRUE ~ status
    )
  ) |>
  dplyr::select(
    manuscript_label, title, canonical_artifact_path,
    alias_artifact_path, existence_status
  )

render_table_pdf(
  manuscript_asset_audit,
  caption = "Manuscript-facing figure and table asset audit",
  file_stub = "manuscript_asset_audit",
  wide = TRUE,
  digits = 0,
  max_cols = 5,
  landscape = TRUE
)
